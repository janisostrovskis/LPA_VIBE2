# LPA local development environment.
# Copy this file to `.env` and fill in real values for your local setup.
# `.env` itself is gitignored. NEVER commit real secrets.

# ---- Database ----
POSTGRES_USER=lpa
POSTGRES_PASSWORD=lpa
POSTGRES_DB=lpa

# Connection string used by the backend (psycopg3 driver).
# Inside docker compose: host = "db" (the service name).
# From host machine: host = "localhost".
DATABASE_URL=postgresql://lpa:lpa@db:5432/lpa

# ---- Backend ----
# Port the FastAPI app binds inside the container.
BACKEND_PORT=8000

# ---- Auth (placeholders for future sub-phases) ----
# JWT_SECRET=change-me-in-real-deployment  # pragma: allowlist secret
# MAGIC_LINK_TTL_MINUTES=15

# ---- Payments (placeholder, set in Phase 4) ----
# PAYMENT_PROVIDER=montonio
# PAYMENT_API_KEY=
# PAYMENT_WEBHOOK_SECRET=

# ---- Frontend (placeholder, set in 00c) ----
# NEXT_PUBLIC_API_URL=http://localhost:8000
