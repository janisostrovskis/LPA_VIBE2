{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",

      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git blame*)",
      "Bash(git remote -v)",

      "Bash(git -C * status*)",
      "Bash(git -C * log*)",
      "Bash(git -C * diff*)",
      "Bash(git -C * branch*)",
      "Bash(git -C * show*)",
      "Bash(git -C * stash list*)",
      "Bash(git -C * blame*)",

      "Bash(cd backend && python -m pytest*)",
      "Bash(cd frontend && npx vitest*)",
      "Bash(cd frontend && npx playwright*)",

      "Bash(python scripts/check_file_size.py*)",
      "Bash(python scripts/check_cola_imports.py*)",
      "Bash(python scripts/security_scan.py*)",
      "Bash(python scripts/check_handoff_log.py*)",
      "Bash(python scripts/log_handoff_timing.py*)",
      "Bash(python scripts/preflight_dispatch.py*)",

      "Bash(docker info*)",
      "Bash(docker ps*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down)",
      "Bash(docker compose build*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose restart*)",
      "Bash(docker compose config*)",
      "Bash(docker compose exec backend python*)",
      "Bash(docker compose exec backend alembic*)",
      "Bash(docker compose exec backend pytest*)",
      "Bash(docker compose exec backend pip list*)",
      "Bash(docker compose exec backend pip show*)",
      "Bash(docker compose exec backend pip install -e *)",
      "Bash(docker compose exec -w * backend python*)",
      "Bash(docker compose exec frontend npm run*)",
      "Bash(docker compose exec frontend npm test*)",
      "Bash(docker compose exec frontend npx*)",
      "Bash(docker compose exec db psql*)",

      "Bash(alembic current*)",
      "Bash(alembic history*)",
      "Bash(alembic show*)",
      "Bash(alembic heads*)",

      "Bash(pytest*)",
      "Bash(python -m pytest*)",
      "Bash(python -m mypy*)",
      "Bash(python -m ruff check*)",
      "Bash(python -m ruff format --check*)",
      "Bash(python -c *)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx vitest*)",
      "Bash(npx playwright*)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm run type-check*)",
      "Bash(npm list*)",

      "Bash(ls *)",
      "Bash(ls)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(env)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(tree*)",
      "Bash(diff *)",

      "Bash(curl -sS http://localhost:*)",
      "Bash(curl -sS https://localhost:*)",
      "Bash(curl -sS -o *)",
      "Bash(curl -sS -w *)",
      "Bash(curl -sf http://localhost:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -I http://localhost:*)",

      "Bash(gh run watch*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh api *)",
      "Bash(gh auth status*)",

      "Bash(lsof -i *)",
      "Bash(netstat*)",
      "Bash(ps aux*)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",

      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.development.local)",
      "Read(.env.production)",
      "Read(.env.production.local)",
      "Read(.env.test)",
      "Read(.env.test.local)",
      "Read(.env.staging)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.development.local)",
      "Read(**/.env.production)",
      "Read(**/.env.production.local)",
      "Read(**/.env.test)",
      "Read(**/.env.test.local)",
      "Read(**/.env.staging)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*--no-verify*)",
      "Bash(*force push*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(docker compose down -v*)",
      "Bash(docker volume rm*)",
      "Bash(docker system prune*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(cat | python3 -c \"import sys,json; print(json.load(sys.stdin).get(\\\"file_path\\\",\\\"\\\"))\" 2>/dev/null); if echo \"$FILE\" | grep -qE \"(^|/)\\.env(\\.(local|development|production|test|staging)(\\.local)?)?$\"; then echo \"BLOCKED: Cannot write to real .env files. Use .env.example/.env.sample/.env.template for documentation.\" >&2; exit 2; fi; exit 0'"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/scripts/hooks/pretool_scope_guard.py",
            "statusMessage": "Checking scope guard..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/scripts/hooks/pretool_bash_baseline.py",
            "statusMessage": "Snapshotting baseline..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/scripts/hooks/posttool_bash_scope_guard.py",
            "statusMessage": "Checking Bash scope guard..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  }
}
